# ============================================================
# Task Maestro 環境変数サンプル
# ----------------------------------------------------------
# このファイルを `.env.local` にコピーして各値を埋めること。
# `.env.local` は `.gitignore` 配下なのでコミットされない。
# ============================================================

# ---- Backlog (FR-004) ----
# 取得方法: https://<space>.backlog.com/EditApiSettings.action から個人API キーを発行
BACKLOG_SPACE_DOMAIN=xxx.backlog.com
BACKLOG_API_KEY=

# ---- Google (Calendar / Drive / Docs) (FR-002 / FR-006 / FR-007) ----
# 取得方法:
# 1) Google Cloud Console でプロジェクトを作成
# 2) OAuth 2.0 クライアント ID (デスクトップアプリ) を作成
# 3) OAuth Playground (https://developers.google.com/oauthplayground/) で refresh_token を取得
#    スコープ: calendar / drive.readonly / documents.readonly
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ---- Slack (FR-001、MVP では未使用) ----
# 取得方法: Slack アプリを作成し User OAuth Token を発行 (scope: search:read, channels:history, im:history, mpim:history)
# 複数ワークスペース対応のため JSON 配列形式
# 例: [{"workspaceId":"T01XXXXXX","token":"xoxp-..."}]
SLACK_TOKENS_JSON=[]

# ---- OpenAI (FR-009、MVP では未使用) ----
OPENAI_API_KEY=

# ---- Claude Code CLI (FR-009、MVP では未使用) ----
# PATH に `claude` が通っていれば未設定で OK
CLAUDE_CODE_PATH=

# ---- ログレベル ----
LOG_LEVEL=info
